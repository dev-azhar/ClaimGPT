# =====================================================
# ClaimGPT Environment Variables
# Copy to .env and customize
# =====================================================

# ---- Database
DATABASE_URL=postgresql://claimgpt:claimgpt@localhost:5432/claimgpt

# ---- MinIO (Object Storage)
MINIO_ROOT_USER=claimgpt
MINIO_ROOT_PASSWORD=claimgpt123
MINIO_ENDPOINT=http://localhost:9000

# ---- Auth (Keycloak)
AUTH_ENABLED=false
AUTH_JWKS_URL=http://localhost:8080/realms/claimgpt/protocol/openid-connect/certs
AUTH_JWT_AUDIENCE=claimgpt
AUTH_JWT_SECRET=dev-secret-change-in-production

# ---- Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
METRICS_ENABLED=false

# ---- Chat / LLM
CHAT_LLM_URL=http://localhost:8888/v1/chat/completions
CHAT_LLM_MODEL=llama-3-8b

# ---- Service URLs (for workflow orchestrator)
WORKFLOW_OCR_URL=http://localhost:8002
WORKFLOW_PARSER_URL=http://localhost:8003
WORKFLOW_CODING_URL=http://localhost:8004
WORKFLOW_PREDICTOR_URL=http://localhost:8005
WORKFLOW_VALIDATOR_URL=http://localhost:8006

# ---- Submission
FHIR_ENDPOINT=
FHIR_AUTH_TOKEN=
X12_ENDPOINT=
SUBMISSION_DEFAULT_PAYER=generic

# ---- Logging
LOG_LEVEL=INFO
