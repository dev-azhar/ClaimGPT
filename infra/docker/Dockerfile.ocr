# infra/docker/Dockerfile.ocr — CORRECTED VERSION
# Fixes:
# 1. Adds missing system dependencies (poppler, libsm6, libxrender1)
# 2. Removes dual-responsibility (see separate OCR worker concern fix in audit report)

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for OCR:
# - tesseract-ocr: Main OCR engine
# - libtesseract-dev: Tesseract development headers
# - libgl1, libglib2.0-0: OpenCV runtime dependencies
# - libsm6, libxrender1, libxext6: X11 display libraries (full OpenCV support)
# - poppler-utils: PDF rendering (indirect dependency of pdfplumber)
# - curl: Health check utility
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        tesseract-ocr \
        tesseract-ocr-eng \
        libtesseract-dev \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        poppler-utils \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies (OCR-specific)
COPY services/ocr/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared libs
COPY libs/ /app/libs/

# Copy all services for Celery import resolution
COPY services/ /app/services/

# Copy service code
COPY services/ocr/app/ /app/app/

# Copy entrypoint script
COPY services/ocr/start-ocr.sh /app/start-ocr.sh

# Ensure services and libs are in PYTHONPATH for celery worker import discovery
ENV PYTHONPATH=/app:/app/libs:/app/services

RUN chmod +x /app/start-ocr.sh

EXPOSE 8000

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
