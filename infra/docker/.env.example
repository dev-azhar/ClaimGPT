# =====================================================
# ClaimGPT Environment Variables (Docker Local Setup)
# Copy to .env and customize
# =====================================================

# ---- Database URL (for host-side tooling connect, e.g., Alembic)
DATABASE_URL=postgresql://claimgpt:claimgpt@localhost:5432/claimgpt
DATABASE_READ_URL=postgresql://claimgpt:claimgpt@localhost:5432/claimgpt

# ---- Redis Cache/Broker Settings
REDIS_URL=redis://localhost:6379/0

# ---- MinIO (Object Storage)
MINIO_ROOT_USER=claimgpt
MINIO_ROOT_PASSWORD=claimgpt123
MINIO_ENDPOINT=http://minio:9000

# ---- Celery Broker & Sentinel configuration
CELERY_BROKER_URL=sentinel://redis-sentinel-1:26379/0;sentinel://redis-sentinel-2:26379/0;sentinel://redis-sentinel-3:26379/0
CELERY_RESULT_BACKEND=sentinel://redis-sentinel-1:26379/2;sentinel://redis-sentinel-2:26379/2;sentinel://redis-sentinel-3:26379/2

# ---- Auth (Keycloak - Disabled by default in dev)
AUTH_ENABLED=false
AUTH_JWKS_URL=http://keycloak:8080/realms/claimgpt/protocol/openid-connect/certs
AUTH_JWT_AUDIENCE=claimgpt
AUTH_JWT_SECRET=dev-secret-change-in-production

# ---- Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
METRICS_ENABLED=true
GRAFANA_ROOT_URL=http://localhost:8000/grafana/

# ---- Chat / LLM
CHAT_LLM_URL=http://llm:8888/v1/chat/completions
CHAT_LLM_MODEL=llama-3-8b

# ---- Internal Service Routing (Inside Docker network)
WORKFLOW_OCR_URL=http://ocr:8000
WORKFLOW_PARSER_URL=http://parser:8000
WORKFLOW_CODING_URL=http://coding:8000
WORKFLOW_PREDICTOR_URL=http://predictor:8000
WORKFLOW_VALIDATOR_URL=http://validator:8000

# ---- Submission Settings
FHIR_ENDPOINT=
FHIR_AUTH_TOKEN=
X12_ENDPOINT=
SUBMISSION_DEFAULT_PAYER=generic

# ---- Logging
LOG_LEVEL=INFO

# ---- LLM Configuration & Parsers
PARSER_STRUCTURED_EXTRACTION_ENABLED=false
PARSER_LLM_TIMEOUT_SECONDS=20
LOCAL_LLM_GGUF_PATH=

# ---- OpenRouter API config (Primary LLM for extraction)
# Replace with your actual OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
PARSER_SEMANTIC_CONCURRENCY=2

# Priority order for semantic extraction backend
PARSER_SEMANTIC_BACKEND_ORDER=openrouter,qwen2-vl,layoutlmv3,florence-2,donut

# Thresholds & Timeouts for ICD coding
CODING_DIAGNOSIS_LONG_THRESHOLD=120
CODING_DIAGNOSIS_LLM_TIMEOUT=30

# ---- ICD-10 RAG Settings
CODING_EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
CODING_EMBEDDING_DIM=768
CODING_DISABLE_SCISPACY=True
CODING_ENABLE_LLM_RERANK=1

# ---- Gemini Fallback API config (Immediate fallback when OpenRouter fails)
# Replace with your actual Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
