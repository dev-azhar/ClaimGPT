{
  "realm": "claimgpt",
  "enabled": true,
  "displayName": "ClaimGPT",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full system access" },
      { "name": "reviewer", "description": "Review and approve claims" },
      { "name": "submitter", "description": "Submit claims to payers" },
      { "name": "viewer", "description": "Read-only access" }
    ]
  },
  "defaultRoles": ["viewer"],
  "clients": [
    {
      "clientId": "claimgpt-api",
      "name": "ClaimGPT API",
      "enabled": true,
      "publicClient": false,
      "secret": "changeme-api-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "email", "profile", "roles"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "claimgpt-web",
      "name": "ClaimGPT Web Portal",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001"
      ],
      "defaultClientScopes": ["openid", "email", "profile", "roles"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google Workspace",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET",
        "hostedDomain": "",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    },
    {
      "alias": "microsoft",
      "displayName": "Microsoft Entra ID",
      "providerId": "microsoft",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_AZURE_APP_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_AZURE_APP_CLIENT_SECRET",
        "tenantId": "REPLACE_WITH_AZURE_TENANT_ID_OR_common",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    },
    {
      "alias": "okta",
      "displayName": "Okta",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_OKTA_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_OKTA_CLIENT_SECRET",
        "authorizationUrl": "https://YOUR_OKTA_DOMAIN/oauth2/default/v1/authorize",
        "tokenUrl": "https://YOUR_OKTA_DOMAIN/oauth2/default/v1/token",
        "userInfoUrl": "https://YOUR_OKTA_DOMAIN/oauth2/default/v1/userinfo",
        "logoutUrl": "https://YOUR_OKTA_DOMAIN/oauth2/default/v1/logout",
        "issuer": "https://YOUR_OKTA_DOMAIN/oauth2/default",
        "defaultScope": "openid email profile",
        "validateSignature": "true",
        "useJwksUrl": "true",
        "jwksUrl": "https://YOUR_OKTA_DOMAIN/oauth2/default/v1/keys",
        "syncMode": "IMPORT",
        "clientAuthMethod": "client_secret_post"
      }
    },
    {
      "alias": "saml",
      "displayName": "SAML SSO (Enterprise)",
      "providerId": "saml",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "singleSignOnServiceUrl": "https://YOUR_IDP/sso",
        "singleLogoutServiceUrl": "https://YOUR_IDP/slo",
        "entityId": "https://claimgpt.example.com/auth/realms/claimgpt",
        "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",
        "principalType": "Subject NameID",
        "signatureAlgorithm": "RSA_SHA256",
        "wantAssertionsSigned": "true",
        "wantAssertionsEncrypted": "false",
        "postBindingResponse": "true",
        "postBindingAuthnRequest": "true",
        "validateSignature": "true",
        "signingCertificate": "REPLACE_WITH_IDP_SIGNING_CERTIFICATE_BASE64",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@claimgpt.local",
      "firstName": "System",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": true
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "reviewer",
      "enabled": true,
      "emailVerified": true,
      "email": "reviewer@claimgpt.local",
      "firstName": "Test",
      "lastName": "Reviewer",
      "credentials": [
        {
          "type": "password",
          "value": "reviewer",
          "temporary": true
        }
      ],
      "realmRoles": ["reviewer"]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
